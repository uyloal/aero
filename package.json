{
  "name": "aero",
  "version": "1.0.0",
  "description": "Generate mihomo rule-provider YAML files from upstream sources",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check --write"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "consola": "^3.4.2",
    "ky": "^2.0.2",
    "valibot": "^1.4.0",
    "yaml": "^2.9.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "pnpm": ">=11.1.1",
    "runtime": {
      "name": "bun",
      "version": "1.3",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "^1.3.14"
  }
}
